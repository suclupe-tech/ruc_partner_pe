<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_partner_form_ruc_button" model="ir.ui.view">
        <field name="name">res.partner.form.ruc.button</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='vat']" position="after">
                <button name="action_consultar_ruc"
                        string="Consultar Documento"
                        type="object"
                        class="btn-primary"/>
            </xpath>

        </field>
    </record>

    <record id="partner_search_document_action_button"      model="ir.ui.view">
        <field name="name">res.partner.search.document.button</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <xpath expr="//sheet" position="before">
                <header>
                    <button name="%(action_ruc_partner_wizard)d"
                    string="Buscar DNI/RUC"
                    type="action"
                    class="btn-primary oe_highlight"/>
                </header>
            </xpath>

        </field>
    </record>

</odoo>