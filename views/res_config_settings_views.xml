<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="res_config_settings_view_form_ruc_partner_pe" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.ruc.partner.pe</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//form" position="inside">
                <app data-string="Consulta RUC Perú" string="Consulta RUC Perú" name="ruc_partner_pe">
                    <block title="API de consulta RUC">
                        <setting string="Token API RUC">
                            <field name="ruc_api_token" password="1"/>
                        </setting>
                    </block>
                </app>
            </xpath>

        </field>
    </record>

</odoo>